    ViewBag.subtitle = "Forms";
    var csrfToken = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken;
}


@section Styles {
    <meta name="csrf-token" content="@csrfToken" />
    <link rel="stylesheet" href="/plugins/choices/choices.min.css" />
    <link rel="stylesheet" href="/plugins/uppy/uppy.min.css" />
    <style>
        #uppy-dashboard .uppy-Dashboard-inner {
            width: 100% !important;
            border-radius: 0.5rem !important;
        }
        #uppy-dashboard .uppy-Dashboard-AddFiles {
            border: none !important;
            padding: 8px !important;
        }
        #uppy-dashboard .uppy-Dashboard-AddFiles-title {
            font-size: 0.9rem !important;
            margin-bottom: 4px !important;
        }
        #uppy-dashboard .uppy-DashboardTab-btn {
            padding: 6px 10px !important;
        }
    </style>
}


