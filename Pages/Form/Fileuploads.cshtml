<div id="uppy-dashboard"></div>
<div id="tus-file-list" class="mt-4 hidden">
    <h5 class="mb-3 text-sm font-semibold text-default-600">Datoteke v tej seji</h5>
    <div id="tus-file-items" class="flex flex-col gap-2"></div>
</div>
<div class="card hidden" id="tus-notification-card">
<div class="card-header block">
<h4 class="card-title mb-1.25">Pošlji obvestilo</h4>
<p class="text-default-400">Po končanem nalaganju pošljite obvestilo z informacijami o naloženih datotekah.</p>
</div>
<div class="card-body">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <!-- Levo: povzetek in seznam datotek -->
    <div class="flex flex-col gap-4">
        <div class="p-3 bg-default-50 border border-default-200 rounded-lg">
            <div class="flex items-center justify-between text-sm mb-2">
                <span class="text-default-500">Naložene datoteke:</span>
                <span class="font-medium" id="notif-file-count">0</span>
            </div>
            <div class="flex items-center justify-between text-sm mb-2">
                <span class="text-default-500">Skupna velikost:</span>
                <span class="font-medium" id="notif-total-size">0 B</span>
            </div>
            <div class="flex items-center justify-between text-sm">
                <span class="text-default-500">Mapa (občina):</span>
                <span class="font-medium" id="notif-folder">—</span>
            </div>
        </div>
        <div>
            <label class="form-label">Datoteke</label>
            <div id="notif-file-detail" class="flex flex-col gap-1.5 text-sm text-default-600"></div>
        </div>
    </div>

    <!-- Desno: vnos prejemnikov, sporočila in gumb -->
    <div class="flex flex-col gap-4">
        @if (Model.IsDrsi)
        {
        <div>
            <label class="form-label" for="notif-recipients">Prejemniki <span class="text-danger">*</span></label>
            <textarea id="notif-recipients" class="form-control w-full" rows="5" placeholder="e-poštni naslovi, ločeni z vejico ali novo vrstico..."></textarea>
            <p class="text-default-400 text-xs mt-1">Vnesite enega ali več e-poštnih naslovov (ločite z vejico ali novo vrstico).</p>
        </div>
        }
        <div class="flex-1 flex flex-col">
            <label class="form-label" for="notif-message">Sporočilo</label>
            <textarea id="notif-message" class="form-control w-full flex-1" rows="6" placeholder="Vnesite sporočilo..."></textarea>
        </div>
        <div>
            <div id="notif-alert" class="hidden mb-3"></div>
            <button id="notif-send-btn" type="button" class="btn btn-primary w-full">
                <i class="iconify tabler--send text-base me-1"></i> Pošlji obvestilo
            </button>
        </div>
    </div>

</div>
</div>
</div>
</div>
</main>

