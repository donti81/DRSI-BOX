@page "/dl/{token}"
@model DRSIBOX.Pages.Dl.IndexModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="sl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Prenos datotek</title>
    <style>
        body { font-family: sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f5f5f5; }
        .box { background: #fff; border-radius: 8px; padding: 2rem 2.5rem; max-width: 420px; width: 100%; text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
        .icon { font-size: 2.5rem; margin-bottom: 1rem; }
        h2 { margin: 0 0 0.5rem; font-size: 1.2rem; color: #333; }
        p { color: #666; font-size: 0.95rem; }
    </style>
</head>
<body>
<div class="box">
    @if (Model.ErrorMessage != null)
    {
        <div class="icon">⚠️</div>
        <h2>Prenos ni mogoč</h2>
        <p>@Model.ErrorMessage</p>
    }
    else
    {
        <div class="icon">📦</div>
        <h2>Prenos se začenja…</h2>
        <p>Datoteke se prenašajo. Če se prenos ne začne samodejno, osvežite stran.</p>
    }
</div>
</body>
</html>
