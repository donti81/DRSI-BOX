<!-- Notification detail modal -->
<div class="hs-overlay hs-overlay-open:opacity-100 hs-overlay-open:duration-500 hidden size-full fixed top-0 start-0 z-80 overflow-x-hidden overflow-y-auto pointer-events-none" id="notifDetailModal" role="dialog" tabindex="-1">
<div class="hs-overlay-animation-target hs-overlay-open:scale-100 hs-overlay-open:opacity-100 scale-95 opacity-0 ease-in-out transition-all duration-200 lg:max-w-2xl md:max-w-xl max-w-sm w-full m-3 md:mx-auto flex items-center min-h-[calc(100%-3.5rem)]">
<div class="w-full flex flex-col card pointer-events-auto">

    <div class="card-header flex items-center gap-3">
        <span class="flex size-10 items-center justify-center rounded-full bg-info/15 text-info shrink-0">
            <i class="iconify tabler--mail text-xl"></i>
        </span>
        <div class="flex-1 min-w-0">
            <h4 class="card-title">Podrobnosti sporočila</h4>
            <p class="text-default-400 text-xs" id="modal-sent-at"></p>
        </div>
        <button class="btn btn-sm btn-icon border-0 text-default-400 hover:text-default-600 ms-auto shrink-0" data-hs-overlay="#notifDetailModal" type="button">
            <i class="iconify tabler--x text-lg"></i>
        </button>
    </div>

    <div class="card-body space-y-5">

        <!-- Metadata grid -->
        <div class="grid grid-cols-2 gap-4">
            <div class="p-3 rounded-lg bg-default-50 border border-default-100">
                <p class="text-2xs text-default-400 uppercase tracking-wider mb-1">Poslal</p>
                <p class="text-sm font-medium" id="modal-sent-by">—</p>
            </div>
            <div class="p-3 rounded-lg bg-default-50 border border-default-100">
                <p class="text-2xs text-default-400 uppercase tracking-wider mb-1">Občina</p>
                <p class="text-sm font-medium" id="modal-folder">—</p>
            </div>
            <div class="p-3 rounded-lg bg-default-50 border border-default-100">
                <p class="text-2xs text-default-400 uppercase tracking-wider mb-1">Število datotek</p>
                <p class="text-sm font-medium" id="modal-file-count">—</p>
            </div>
            <div class="p-3 rounded-lg bg-default-50 border border-default-100">
                <p class="text-2xs text-default-400 uppercase tracking-wider mb-1">Skupna velikost</p>
                <p class="text-sm font-medium" id="modal-total-size">—</p>
            </div>
            <div class="p-3 rounded-lg bg-default-50 border border-default-100 col-span-2">
                <p class="text-2xs text-default-400 uppercase tracking-wider mb-1">IP naslov</p>
                <p class="text-sm font-medium font-mono" id="modal-ip">—</p>
            </div>
            <div class="p-3 rounded-lg bg-default-50 border border-default-100 col-span-2">
                <p class="text-2xs text-default-400 uppercase tracking-wider mb-1">Poslano</p>
                <p class="text-sm text-default-700 break-all" id="modal-recipients">—</p>
            </div>
        </div>

        <!-- Files list -->
        <div id="modal-files-section">
            <p class="text-xs font-semibold text-default-500 uppercase tracking-wider mb-2">Datoteke</p>
            <div id="modal-files" class="flex flex-col gap-1.5"></div>
        </div>

        <!-- Message -->
        <div id="modal-message-section" class="hidden">
            <p class="text-xs font-semibold text-default-500 uppercase tracking-wider mb-2">Sporočilo</p>
            <div class="p-3 rounded-lg bg-default-50 border border-default-100">
                <p class="text-sm text-default-700 whitespace-pre-wrap" id="modal-message"></p>
            </div>
        </div>

    </div>

    <div class="card-footer flex justify-between items-center">
        <button class="btn btn-primary" id="modal-download-all-btn" type="button">
            <i class="iconify tabler--download me-1"></i> Prenesi vse
        </button>
        <button class="btn border-default-300" data-hs-overlay="#notifDetailModal" type="button">Zapri</button>
    </div>

</div>
</div>
</div>

@section Scripts {
<script src="js/pages/custom-table.js"></script>
<script>
document.querySelectorAll(".notif-row").forEach(row => {
    row.addEventListener("click", () => {
        const d = row.dataset

        document.getElementById("modal-sent-at").textContent    = d.sentAt
        document.getElementById("modal-sent-by").textContent    = d.sentBy  || "—"
        document.getElementById("modal-folder").textContent     = d.folder  || "—"
        document.getElementById("modal-file-count").textContent = d.fileCount
        document.getElementById("modal-total-size").textContent = d.totalSize
        document.getElementById("modal-ip").textContent         = d.ip      || "—"

        document.getElementById("modal-recipients").textContent = d.recipients || "—"

        // Files list
        const filesEl = document.getElementById("modal-files")
        filesEl.innerHTML = ""
        try {
            const files = JSON.parse(d.files || "[]")
            files.forEach(f => {
                const div = document.createElement("div")
                div.className = "flex items-center gap-2 text-sm py-1.5 border-b border-default-100 last:border-0"
                div.innerHTML = `<i class="iconify tabler--file text-default-400 shrink-0"></i>
                    <span class="flex-1 truncate">${f.name}</span>
                    <span class="text-default-400 text-xs shrink-0">${formatBytes(f.size)}</span>`
                filesEl.appendChild(div)
            })
        } catch {}

        // Message
        const msgSection = document.getElementById("modal-message-section")
        const msgEl = document.getElementById("modal-message")
        if (d.message) {
            msgEl.textContent = d.message
            msgSection.classList.remove("hidden")
        } else {
            msgSection.classList.add("hidden")
        }

        document.getElementById("modal-download-all-btn").dataset.notifId = d.id
        HSOverlay.open(document.getElementById("notifDetailModal"))
    })
})

document.getElementById("modal-download-all-btn")?.addEventListener("click", function() {
    if (this.dataset.notifId)
        window.location.href = `/apps/file-manager?handler=DownloadAll&notifId=${this.dataset.notifId}`
})

function formatBytes(bytes) {
    bytes = Number(bytes)
    if (bytes < 1024) return bytes + " B"
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + " KB"
    return (bytes / 1048576).toFixed(1) + " MB"
}
</script>
}
