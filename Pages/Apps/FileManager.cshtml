<select class="form-select" data-table-set-rows-per-page="">
<option value="5">5</option>
<option value="8">8</option>
<option value="10">10</option>
<option value="15">15</option>
<option value="20">20</option>
</select>
</div>
</div>
</div>
<div class="card-body">

@if (Model.View == "recent")
{
    <!-- Recent activity view -->
    <div class="table-wrapper">
        <table class="table table-hover">
            <thead class="thead-sm border-t border-default-200">
                <tr class="bg-light/25 text-2xs uppercase">
                    <th>Event</th>
                    <th data-table-sort="name">Name</th>
                    <th>Size</th>
                    <th>By</th>
                    <th data-table-sort="">When</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.RecentActivity.Any())
            {
                <tr>
                    <td class="text-center text-default-400 py-8" colspan="5">No activity yet.</td>
                </tr>
            }
            @foreach (var item in Model.RecentActivity)
            {
                var (badgeClass, iconClass) = item.EventType switch {
                    "Uploaded"   => ("bg-success/15 text-success",  "tabler--upload"),
                    "Downloaded" => ("bg-primary/15 text-primary",  "tabler--download"),
                    _            => ("bg-danger/15 text-danger",    "tabler--trash")
                };
                <tr>
                    <td>
                        <span class="badge @badgeClass font-semibold">
                            <i class="iconify @iconClass me-1"></i>@item.EventType
                        </span>
                    </td>
                    <td>
                        <div class="flex items-center gap-2.5">
                            <div class="bg-light/50 text-default-400 flex size-9 items-center justify-center rounded">
                                <i class="iconify @FileIcon(item.ContentType) text-xl"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">@item.OriginalName</h5>
                            </div>
                        </div>
                    </td>
                    <td>@FormatSize(item.FileSize)</td>
                    <td><span class="text-default-400 text-xs">@(item.EventBy ?? "—")</span></td>
                    <td><span class="text-default-400 text-xs">@item.EventAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</span></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else if (Model.View == "trash")
{
    <!-- Trash view -->
    <div class="table-wrapper">
        <table class="table table-hover">
            <thead class="thead-sm border-t border-default-200">
                <tr class="bg-light/25 text-2xs uppercase">
                    <th data-table-sort="name">Name</th>
                    <th data-column="type" data-table-sort="">Type</th>
                    <th>Size</th>
                    <th data-table-sort="">Uploaded by</th>
                    <th data-table-sort="">Deleted by</th>
                    <th data-table-sort="">Deleted at</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.DeletedFiles.Any())
            {
                <tr>
                    <td class="text-center text-default-400 py-8" colspan="6">Trash is empty.</td>
                </tr>
            }
            @foreach (var file in Model.DeletedFiles)
            {
                <tr>
                    <td>
                        <div class="flex items-center gap-2.5">
                            <div class="bg-light/50 text-default-400 flex size-9 items-center justify-center rounded">
                                <i class="iconify @FileIcon(file.ContentType) text-xl"></i>
                            </div>
                            <div>
                                <h5 class="mb-1.25 text-default-500">@file.OriginalName</h5>
                                <p class="text-default-400 text-xs">@FormatSize(file.FileSize)</p>
                            </div>
                        </div>
                    </td>
                    <td>@FileTypeLabel(file.ContentType, file.OriginalName)</td>
                    <td>@FormatSize(file.FileSize)</td>
                    <td><span class="text-default-400 text-xs">@(file.UploadedBy ?? "—")</span></td>
                    <td><span class="text-default-400 text-xs">@(file.DeletedBy ?? "—")</span></td>
                    <td><span class="text-default-400 text-xs">@(file.DeletedAt?.ToLocalTime().ToString("MMM d, yyyy HH:mm") ?? "—")</span></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else if (Model.View == "downloads")
{
    <!-- Downloads view -->
    <div class="table-wrapper">
        <table class="table table-hover">
            <thead class="thead-sm border-t border-default-200">
                <tr class="bg-light/25 text-2xs uppercase">
                    <th data-table-sort="name">Name</th>
                    <th data-column="type" data-table-sort="">Type</th>
                    <th data-table-sort="downloads">Downloads</th>
                    <th data-table-sort="">Last Downloaded</th>
                    <th>Downloaded by</th>
                    <th>Uploaded by</th>
                    <th>Size</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.DownloadedFiles.Any())
            {
                <tr>
                    <td class="text-center text-default-400 py-8" colspan="6">No downloads yet.</td>
                </tr>
            }
            @foreach (var file in Model.DownloadedFiles)
            {
                <tr>
                    <td>
                        <div class="flex items-center gap-2.5">
                            <div class="bg-light/50 text-default-400 flex size-9 items-center justify-center rounded">
                                <i class="iconify @FileIcon(file.ContentType) text-xl"></i>
                            </div>
                            <div>
                                <h5 class="mb-1.25">
                                    <a class="hover:text-primary" href="apps/file-manager?handler=Download&id=@file.UploadLogId">@file.OriginalName</a>
                                </h5>
                                <p class="text-default-400 text-xs">@FormatSize(file.FileSize)</p>
                            </div>
                        </div>
                    </td>
                    <td>@FileTypeLabel(file.ContentType, file.OriginalName)</td>
                    <td data-sort="downloads">
                        <span class="badge bg-primary/15 text-primary font-semibold">@file.DownloadCount</span>
                    </td>
                    <td>@file.LastDownloadedAt.ToLocalTime().ToString("MMM d, yyyy HH:mm")</td>
                    <td><span class="text-default-400 text-xs">@(file.LastDownloadedBy ?? "—")</span></td>
                    <td><span class="text-default-400 text-xs">@(file.UploadedBy ?? "—")</span></td>
                    <td>@FormatSize(file.FileSize)</td>
                    <td>
                        <div class="flex items-center justify-end gap-3">
                            <a class="btn btn-sm btn-icon border-default-300"
                               href="apps/file-manager?handler=Download&id=@file.UploadLogId"
                               title="Download">
                                <i class="iconify tabler--download text-default-600"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else if (Model.View == "notifications")
{
    <!-- Sent notifications view -->
    <div class="table-wrapper">
        <table class="table table-hover">
            <thead class="thead-sm border-t border-default-200">
                <tr class="bg-light/25 text-2xs uppercase">
                    <th data-table-sort="">Kdaj</th>
                    <th data-table-sort="">Poslal</th>
                    <th data-table-sort="">Občina</th>
                    <th data-table-sort="">Datotek</th>
                    <th data-table-sort="">Skupaj</th>
                    <th>Poslano</th>
                    <th>Sporočilo</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Notifications.Any())
            {
                <tr>
                    <td class="text-center text-default-400 py-8" colspan="7">Ni poslanih sporočil.</td>
                </tr>
            }
            @foreach (var n in Model.Notifications)
            {
                <tr class="cursor-pointer notif-row"
                    data-id="@n.Id"
                    data-sent-at="@n.SentAt.ToLocalTime().ToString("d. M. yyyy HH:mm")"
                    data-sent-by="@(n.SentBy ?? "")"
                    data-folder="@(n.Folder ?? "")"
                    data-file-count="@n.FileCount"
                    data-total-size="@FormatSize(n.TotalSize)"
                    data-files="@(n.FilesDetail ?? "[]")"
                    data-message="@(n.Message ?? "")"
                    data-ip="@(n.IpAddress ?? "")"
                    data-recipients="@(n.Recipients ?? "")">
                    <td><span class="text-default-400 text-xs text-nowrap">@n.SentAt.ToLocalTime().ToString("d. M. yyyy HH:mm")</span></td>
                    <td><span class="text-default-400 text-xs">@(n.SentBy ?? "—")</span></td>
                    <td><span class="text-xs font-medium">@(n.Folder ?? "—")</span></td>
                    <td><span class="badge bg-info/15 text-info font-semibold text-2xs">@n.FileCount</span></td>
                    <td><span class="text-xs">@FormatSize(n.TotalSize)</span></td>
                    <td>
                        @if (!string.IsNullOrEmpty(n.Recipients))
                        {
                            <span class="text-xs text-default-600 line-clamp-2 max-w-xs block">@n.Recipients</span>
                        }
                        else
                        {
                            <span class="text-default-300 text-xs italic">—</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(n.Message))
                        {
                            <span class="text-xs text-default-600 line-clamp-2 max-w-xs block">@n.Message</span>
                        }
                        else
                        {
                            <span class="text-default-300 text-xs italic">brez sporočila</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <!-- My Files: table with download count column -->
    <div class="table-wrapper">
        <table class="table table-hover">
            <thead class="thead-sm border-t border-default-200">
                <tr class="bg-light/25 text-2xs uppercase">
                    <th class="w-[1%]">
                        <input class="form-checkbox form-checkbox-light size-4.5" data-table-select-all="" id="checkAll" type="checkbox"/>
                    </th>
                    <th data-table-sort="name">Name</th>
                    <th data-column="type" data-table-sort="">Type</th>
                    <th data-table-sort="">Modified</th>
                    <th data-table-sort="owner">Uploaded by</th>
                    <th data-column="obcina" data-table-sort="">Občina</th>
                    <th data-table-sort="downloads">Downloads</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Files.Any())
            {
                <tr>
                    <td class="text-center text-default-400 py-8" colspan="8">No files uploaded yet.</td>
                </tr>
            }
            @foreach (var file in Model.Files)
            {
                var dlCount = Model.DownloadCounts.GetValueOrDefault(file.Id, 0);
                <tr>
                    <td><input class="form-checkbox form-checkbox-light size-4.5" type="checkbox" value="option"/></td>
                    <td>
                        <div class="flex items-center gap-2.5">
                            <div class="bg-light/50 text-default-400 flex size-9 items-center justify-center rounded">
                                <i class="iconify @FileIcon(file.ContentType) text-xl"></i>
                            </div>
                            <div>
                                <h5 class="mb-1.25">
                                    <a class="hover:text-primary" data-sort="name" href="apps/file-manager?handler=Download&id=@file.Id">@file.OriginalName</a>
                                </h5>
                                <p class="text-default-400 text-xs">@FormatSize(file.FileSize)</p>
                            </div>
                        </div>
                    </td>
                    <td>@FileTypeLabel(file.ContentType, file.OriginalName)</td>
                    <td>@file.UploadedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                    <td>
                        <span class="text-default-400 text-xs">@(file.UploadedBy ?? "—")</span>
                    </td>
                    <td data-column="obcina">
                        <span class="text-default-400 text-xs">@(file.Folder ?? "—")</span>
                    </td>
                    <td data-sort="downloads">
                        @if (dlCount > 0)
                        {
                            <span class="badge bg-primary/15 text-primary font-semibold">@dlCount</span>
                        }
                        else
                        {
                            <span class="text-default-400 text-xs">—</span>
                        }
                    </td>
                    <td>
                        <div class="flex items-center justify-end gap-3">
                            <div class="hs-dropdown relative inline-flex [--placement:bottom-right]">
                                <button aria-expanded="false" aria-haspopup="menu" aria-label="Dropdown"
                                        class="hs-dropdown-toggle text-xl text-default-400" type="button">
                                    <i class="iconify tabler--dots-vertical text-xl"></i>
                                </button>
                                <div aria-orientation="vertical" class="hs-dropdown-menu" role="menu">
                                    <div class="space-y-0.5">
                                        <a class="dropdown-item" href="apps/file-manager?handler=Download&id=@file.Id">
                                            <i class="iconify tabler--download"></i> Download
                                        </a>
                                        <form method="post" asp-page-handler="Delete">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@file.Id"/>
                                            <button type="submit" class="dropdown-item w-full text-start text-danger">
                                                <i class="iconify tabler--trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

</div>
<!-- end card-body -->
