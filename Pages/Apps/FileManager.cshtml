@page "/apps/file-manager"
@model DRSIBOX.Pages.Apps.FileManagerModel

@functions {
    static string FileIcon(string? ct) => ct switch {
        string s when s.StartsWith("image/") => "tabler--photo",
        string s when s.StartsWith("video/") => "tabler--video",
        string s when s.StartsWith("audio/") => "tabler--music",
        "application/pdf" => "tabler--file-type-pdf",
        _ => "tabler--file"
    };

    static string FileTypeLabel(string? ct, string fileName) {
        if (ct is null) return System.IO.Path.GetExtension(fileName).TrimStart('.').ToUpper();
        return ct switch {
            string s when s.StartsWith("image/") => "Image",
            string s when s.StartsWith("video/") => "Video",
            string s when s.StartsWith("audio/") => "Audio",
            "application/pdf" => "PDF",
            _ => System.IO.Path.GetExtension(fileName).TrimStart('.').ToUpper()
        };
    }

    static string FormatSize(long bytes) => bytes switch {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        < 1024L * 1024 * 1024 => $"{bytes / 1024.0 / 1024:F1} MB",
        _ => $"{bytes / 1024.0 / 1024 / 1024:F2} GB"
    };
}

